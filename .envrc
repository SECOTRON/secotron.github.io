# direnv — automatically loaded when entering this directory.
# Install direnv: brew install direnv  then add the hook to your shell rc file:
#   zsh:  eval "$(direnv hook zsh)"   → ~/.zshrc
#   bash: eval "$(direnv hook bash)"  → ~/.bashrc
# Run `direnv allow` once per machine after cloning.

# If you also use a standard .env file for development secrets:
dotenv_if_exists .env

# Copy to .envrc.local (git-ignored) and fill in. Then run `direnv allow`.
# Cloudflare Turnstile keys — https://dash.cloudflare.com → Turnstile.
#   SITEKEY is public (rendered in the page). SECRET is private (Function only).
# export TURNSTILE_SITEKEY=**********
# export TURNSTILE_SECRET=**********

# Source the local environment file if it exists (git-ignored)
source_env .envrc.local
