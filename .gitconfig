[alias]
	# Fuzzy-pick a GitHub org, clone all its non-archived repos and open them in VS Code
	cloneorg = !org=$(gh org list | tail -n +1 | awk '{print $1}' | fzf) && gh repo list $org --no-archived -L 500 | tail -n +2 | awk '{print $1}' | xargs -I % sh -c 'gh repo clone % && code -a $(echo % | cut -d/ -f2)/'

	# Fuzzy-pick a recent commit and create a fixup commit (auto-squashed on next rebase)
	fixup = !git log -n 50 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git commit --fixup
